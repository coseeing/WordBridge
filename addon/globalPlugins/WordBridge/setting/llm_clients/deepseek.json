{
	"name": "deepseek",
	"url": "https://api.deepseek.com/chat/completions",
	"setting": {
		"max_tokens": 4096,
		"temperature": 0.0,
		"top_p": 0.0,
		"stop": [ " =>" ]
	},
	"timeout0": 30,
	"timeout_max": 60,
	"usage_schemas": {
		"deepseek_standard": {
			"usage_key": "usage",
			"fields": ["prompt_cache_hit_tokens", "prompt_cache_miss_tokens", "completion_tokens"]
		}
	}
}